{
  "name": "chassis-workbench",
  "version": "1.0.0",
  "description": "Motorcycle Chassis Dynamics Workbench — Foale / Cossalter",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "npm run build && electron .",
    "electron:run": "electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:dist": "npm run build && electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.1",
    "three": "^0.183.2",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.1.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.chassis.workbench",
    "productName": "Chassis Workbench",
    "copyright": "Motorcycle Chassis Dynamics — Foale/Cossalter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Science",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    }
  }
}
